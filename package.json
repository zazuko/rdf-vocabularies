{
  "name": "@zazuko/rdf-vocabularies",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky install",
    "fetch": "npm run -ws --if-present fetch",
    "lint": "eslint . --ext .js,.ts --quiet",
    "pretest": "npm -w @zazuko/vocabularies run combine-meta",
    "test": "c8 -i src mocha packages/**/*.test.ts",
    "posttest": "c8 report --reporter=text-lcov >> ./coverage/lcov.info",
    "postinstall": "patch-package",
    "release": "changeset publish"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zazuko/rdf-vocabularies",
    "directory": "."
  },
  "author": "Victor Felder <victor@draft.li> (https://draft.li)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/zazuko/rdf-vocabularies/issues"
  },
  "homepage": "https://github.com/zazuko/rdf-vocabularies#readme",
  "devDependencies": {
    "@changesets/cli": "^3.0.0-next.8",
    "@eslint/js": "^9",
    "@tpluscode/eslint-config": "^1.1.0",
    "c8": "^11.0.0",
    "eslint": "^9",
    "eslint-config-flat-gitignore": "^2.3.0",
    "husky": "^8.0.3",
    "lint-staged": "^13.1.2",
    "mocha": "^12.0.0-rc.1",
    "patch-package": "^8",
    "postinstall-postinstall": "^2.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },
  "mocha": {
    "extension": "ts",
    "watch-files": [
      "./**/*.ts"
    ],
    "require": "tsx"
  },
  "workspaces": [
    "./packages/*",
    "./ontologies/*"
  ],
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix --quiet"
    ]
  }
}
